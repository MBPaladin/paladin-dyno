{
  "//": "LaTeX Workshop: use MiKTeX pdflatex directly (no latexmk/Perl needed). Absolute path so it works even before a VS Code PATH refresh.",
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "C:/Users/Nathan Justus/AppData/Local/Programs/MiKTeX/miktex/bin/x64/pdflatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex x2",
      "tools": ["pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.recipe.default": "pdflatex x2",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof", "*.lot",
    "*.out", "*.toc", "*.acn", "*.acr", "*.alg", "*.glg", "*.glo",
    "*.gls", "*.fls", "*.fdb_latexmk", "*.synctex.gz"
  ]
}
